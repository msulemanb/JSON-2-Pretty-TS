{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "compilerOptions": {
    "moduleResolution": "bundler", // OVERRIDE: Forces modern module bundling resolution
    "paths": {
      "*": [
        "./*"
      ]
    },
    "types": ["node", "chrome"]
  }
}